# ── Database ───────────────────────────────────────────
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgrespassword
POSTGRES_DB=arabic_ai
POSTGRES_PORT=4444

# ── Backend ───────────────────────────────────────────
# Connection for backend to DB (use 'db' as host inside Docker)
DATABASE_URL=postgresql+asyncpg://postgres:postgrespassword@db:4444/arabic_ai
JWT_SECRET=super-secure-key-change-me

# ── AI Services (ASR/Vision/LLM) ──────────────────────
LONGCAT_API_KEY=your-api-key-here
FASTSCRIBE_URL=https://fastscribe.tarjama.com/api/asr/
VISION_API_URL=https://vision-api.arabic.ai/vision/extract

# ── Frontend ──────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8000
